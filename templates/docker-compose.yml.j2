name: "{{ ara_compose_project_name }}"

services:
  ara-api:
    image: {{ ara_image }}
    container_name: {{ ara_container_name }}
    hostname: {{ ara_container_hostname }}
    restart: unless-stopped
    tty: true
    environment:
      ARA_EXTERNAL_AUTH: "{{ ara_external_auth | ternary('true', 'false') }}"
      ARA_READ_LOGIN_REQUIRED: "{{ ara_read_login_required | ternary('true', 'false') }}"
      ARA_WRITE_LOGIN_REQUIRED: "{{ ara_write_login_required | ternary('true', 'false') }}"
      ARA_ALLOWED_HOSTS: '{{ ara_effective_allowed_hosts | to_json }}'
      ARA_CSRF_TRUSTED_ORIGINS: '{{ ara_effective_csrf_trusted_origins | to_json }}'
      ARA_CORS_ORIGIN_WHITELIST: '{{ ara_effective_cors_origin_whitelist | to_json }}'
    expose:
      - "{{ ara_container_port }}"
    volumes:
      - {{ ara_data_dir }}:/opt/ara
    networks:
      - ara-internal

  ara-nginx-api:
    image: {{ ara_nginx_image }}
    container_name: {{ ara_nginx_api_container_name }}
    hostname: {{ ara_nginx_api_container_hostname }}
    restart: unless-stopped
    depends_on:
      - ara-api
{% if ara_prometheus_enabled %}
      - ara-prometheus
{% endif %}
    ports:
{% if not (ara_enable_tls and ara_nginx_listen_ssl_only) %}
      - "{{ ara_nginx_bind_address }}:{{ ara_api_http_port }}:80"
{% endif %}
{% if ara_enable_tls %}
      - "{{ ara_nginx_bind_address }}:{{ ara_api_https_port }}:443"
{% endif %}
    volumes:
      - {{ ara_compose_dir }}/nginx.conf:/etc/nginx/nginx.conf:ro
      - {{ ara_compose_dir }}/ara-api.conf:/etc/nginx/conf.d/ara-api.conf:ro
      - {{ ara_auth_dir }}:/etc/nginx/auth:ro
{% if ara_enable_tls %}
      - {{ ara_tls_cert_path }}:/opt/fullchain.pem:ro
      - {{ ara_tls_key_path }}:/opt/privkey.pem:ro
{% endif %}
    networks:
      - ara-internal

  ara-nginx-web:
    image: {{ ara_nginx_image }}
    container_name: {{ ara_nginx_web_container_name }}
    hostname: {{ ara_nginx_web_container_hostname }}
    restart: unless-stopped
    depends_on:
      - ara-api
    ports:
{% if not (ara_enable_tls and ara_nginx_listen_ssl_only) %}
      - "{{ ara_nginx_bind_address }}:{{ ara_web_http_port }}:80"
{% endif %}
{% if ara_enable_tls %}
      - "{{ ara_nginx_bind_address }}:{{ ara_web_https_port }}:443"
{% endif %}
    volumes:
      - {{ ara_compose_dir }}/nginx.conf:/etc/nginx/nginx.conf:ro
      - {{ ara_compose_dir }}/ara-web.conf:/etc/nginx/conf.d/ara-web.conf:ro
      - {{ ara_auth_dir }}:/etc/nginx/auth:ro
{% if ara_enable_tls %}
      - {{ ara_tls_cert_path }}:/opt/fullchain.pem:ro
      - {{ ara_tls_key_path }}:/opt/privkey.pem:ro
{% endif %}
    networks:
      - ara-internal


{%- if ara_prometheus_enabled %}
  ara-nginx-prometheus:
    image: {{ ara_nginx_image }}
    container_name: {{ ara_nginx_prometheus_container_name }}
    hostname: {{ ara_nginx_prometheus_container_hostname }}
    restart: unless-stopped
    depends_on:
      - ara-prometheus
    ports:
{% if not (ara_enable_tls and ara_nginx_listen_ssl_only) %}
      - "{{ ara_nginx_bind_address }}:{{ ara_prometheus_http_port }}:80"
{% endif %}
{% if ara_enable_tls %}
      - "{{ ara_nginx_bind_address }}:{{ ara_prometheus_https_port }}:443"
{% endif %}
    volumes:
      - {{ ara_compose_dir }}/nginx.conf:/etc/nginx/nginx.conf:ro
      - {{ ara_compose_dir }}/ara-prometheus.conf:/etc/nginx/conf.d/ara-prometheus.conf:ro
      - {{ ara_auth_dir }}:/etc/nginx/auth:ro
{% if ara_enable_tls %}
      - {{ ara_tls_cert_path }}:/opt/fullchain.pem:ro
      - {{ ara_tls_key_path }}:/opt/privkey.pem:ro
{% endif %}
    networks:
      - ara-internal
{%- endif %}

{%- if ara_prometheus_enabled %}
  ara-prometheus:
{% if ara_prometheus_build_locally %}
    build:
      context: {{ ara_compose_dir }}
      dockerfile: ara-prometheus.Dockerfile
{% else %}
    image: {{ ara_prometheus_image_name }}:{{ ara_prometheus_image_version }}
{% endif %}
    container_name: {{ ara_prometheus_container_name }}
    hostname: {{ ara_prometheus_container_hostname }}
    restart: unless-stopped
    depends_on:
      - ara-api
    tty: true
    environment:
      ARA_API_CLIENT: http
      ARA_API_SERVER: http://{{ ara_container_hostname }}:{{ ara_container_port }}
      ARA_PROMETHEUS_PORT: "{{ ara_prometheus_port }}"
      ARA_PROMETHEUS_TEXTFILE_ENABLED: "{{ ara_prometheus_textfile_enabled | ternary('true', 'false') }}"
{% if ara_prometheus_textfile_enabled %}
      ARA_PROMETHEUS_TEXTFILE_PATH: "{{ ara_prometheus_textfile_dir }}/{{ ara_prometheus_textfile_filename }}"
      ARA_PROMETHEUS_TEXTFILE_INTERVAL: "{{ ara_prometheus_textfile_interval }}"
{% endif %}
    command:
      - ara
      - prometheus
      - --prometheus-port
      - "{{ ara_prometheus_port }}"
      - --prometheus-address
      - 0.0.0.0
      - --refresh-interval
      - "{{ ara_prometheus_refresh_interval }}"
      - --playbook-limit
      - "{{ ara_prometheus_playbook_limit }}"
      - --task-limit
      - "{{ ara_prometheus_task_limit }}"
      - --host-limit
      - "{{ ara_prometheus_host_limit }}"
{% if ara_prometheus_textfile_enabled %}
    volumes:
      - {{ ara_prometheus_local_textfile_dir }}:{{ ara_prometheus_textfile_dir }}
{% endif %}
    expose:
      - "{{ ara_prometheus_port }}"
    networks:
      - ara-internal
{%- endif %}

networks:
  ara-internal:
    name: {{ ara_network_name }}
    driver: bridge

